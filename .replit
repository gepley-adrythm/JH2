modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Dev"

[[workflows.workflow]]
name = "Dev"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "site dev"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "prewarm"

[[workflows.workflow]]
name = "site dev"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/jematell-homes run dev"

[[workflows.workflow]]
name = "api server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 pnpm --filter @workspace/api-server run dev"

[[workflows.workflow]]
name = "prewarm"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node artifacts/jematell-homes/scripts/prewarm-dev.mjs"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "audit"

[[workflows.workflow]]
name = "audit"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/jematell-homes run audit:ci"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["google-mail:1.0.0", "google-drive:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 24862
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "8080"
BASE_PATH = "/"
NODE_ENV = "development"
