{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*", "app/**/*", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "build", "dist", "out", "**/*.test.ts"],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["esnext", "dom", "dom.iterable"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "incremental": true,
    "tsBuildInfoFile": ".next/tsbuildinfo",
    "types": ["node"],
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "references": [
    {
      "path": "../../lib/faq"
    }
  ]
}
