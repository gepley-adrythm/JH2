{
  "name": "@workspace/jematell-homes",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash ../../scripts/dev-supervisor.sh web 8080 pnpm run dev:raw",
    "dev:raw": "NEXT_TELEMETRY_DISABLED=1 NODE_OPTIONS=--max-old-space-size=4096 next dev -H 0.0.0.0",
    "build": "next build && node scripts/precompress.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "audit": "node scripts/audit.mjs",
    "audit:ci": "NODE_ENV=production pnpm run build && node scripts/audit.mjs && node scripts/content-lint.mjs",
    "lint:content": "node scripts/content-lint.mjs",
    "lint:content:ci": "NODE_ENV=production pnpm run build && node scripts/content-lint.mjs"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@workspace/faq": "workspace:*",
    "axe-core": "^4.12.0",
    "clsx": "catalog:",
    "jsdom": "^29.1.1",
    "tailwind-merge": "catalog:"
  },
  "dependencies": {
    "framer-motion": "catalog:",
    "leaflet": "^1.9.4",
    "lucide-react": "catalog:",
    "next": "^16.1.0",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
